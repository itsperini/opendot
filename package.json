{
  "name": "opendot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.10 <25",
    "pnpm": "11.1.3"
  },
  "scripts": {
    "dev": "pnpm --filter ./platform run dev",
    "api": "pnpm --filter ./platform run api",
    "runtime": "pnpm --filter ./platform run runtime",
    "lint": "pnpm --filter ./platform run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter ./platform run test",
    "build": "pnpm --filter ./platform run build",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm run build",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3"
  }
}
