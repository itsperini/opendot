{
  "name": "opendot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.x",
    "pnpm": "11.1.3"
  },
  "scripts": {
    "dev": "pnpm --filter ./platform run dev",
    "api": "pnpm --filter ./platform run api",
    "runtime": "pnpm --filter ./platform run runtime",
    "lint": "pnpm --filter ./platform run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter ./platform run test",
    "build": "pnpm --filter ./platform run build",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
