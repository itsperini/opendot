DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# Optional runtime defaults. The browser agent config can override most visible pipeline fields.
OPENAI_MODEL=gpt-5.4-mini
OPENDOT_SYSTEM_PROMPT=You are a concise voice assistant. Answer naturally in one or two short spoken paragraphs.
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANGUAGE=en-US
DEEPGRAM_ENDPOINTING_MS=900
DEEPGRAM_UTTERANCE_END_MS=1000
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_TTS_ENCODING=mp3
DEEPGRAM_TTS_SAMPLE_RATE=24000
MIN_TRANSCRIPT_CHARS=2
CLOSE_DEVICE_AFTER_TURN=true
CLOSE_DEVICE_AFTER_TURN_DELAY_MS=300
RUNTIME_PORT=8787
