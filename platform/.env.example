DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# Platform API and Postgres. Use the Compose default locally, or set this to
# a Supabase Postgres connection string and POSTGRES_SSL=true.
POSTGRES_URI=postgres://opendot:opendot@localhost:5432/opendot
POSTGRES_SSL=false
PLATFORM_API_HOST=0.0.0.0
PLATFORM_API_PORT=8788

# Optional Supabase Auth bridge. Leave empty for local/dev mode. SUPABASE_URL
# enables JWKS verification; SUPABASE_JWT_SECRET is only needed for legacy HS256 projects.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
PLATFORM_AUTH_REQUIRED=false

VITE_PLATFORM_API_URL=/api
VITE_RUNTIME_WS_URL=ws://localhost:8787/voice
VITE_RUNTIME_HTTP_URL=http://localhost:8787

# Optional runtime defaults. The browser agent config can override most visible pipeline fields.
OPENAI_MODEL=gpt-5.4-mini
OPENDOT_SYSTEM_PROMPT=You are a concise voice assistant. Answer naturally in one or two short spoken paragraphs.
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANGUAGE=en-US
DEEPGRAM_ENDPOINTING_MS=900
DEEPGRAM_UTTERANCE_END_MS=1000
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_TTS_ENCODING=mp3
DEEPGRAM_TTS_SAMPLE_RATE=24000
MIN_TRANSCRIPT_CHARS=2
CLOSE_DEVICE_AFTER_TURN=true
CLOSE_DEVICE_AFTER_TURN_DELAY_MS=300
RUNTIME_PORT=8787
