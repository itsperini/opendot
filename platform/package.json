{
  "name": "opendot-platform-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.10 <25",
    "pnpm": "11.1.3"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api:dev": "tsx watch src/server/api.ts",
    "api": "tsx src/server/api.ts",
    "runtime": "node src/server/runtime.js",
    "build": "tsc --noEmit && pnpm run build:server && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "opusscript": "^0.1.1",
    "pg": "^8.21.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.4"
  }
}
