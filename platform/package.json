{
  "name": "opendot-platform-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api:dev": "tsx watch src/server/api.ts",
    "api": "tsx src/server/api.ts",
    "runtime": "node src/server/runtime.js",
    "build": "tsc --noEmit && npm run build:server && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@supabase/supabase-js": "^2.106.1",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "lucide-react": "^0.453.0",
    "opusscript": "^0.1.1",
    "pg": "^8.21.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "5.6.3",
    "vite": "^7.1.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3"
  }
}
