{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenDot",
  "description": "Docs for building voice agents, tuning pipelines, binding hardware, and operating sessions across cloud, local, and device runtimes.",
  "colors": {
    "primary": "#5B21B6",
    "light": "#7C3AED",
    "dark": "#2E1065"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "icon": {
            "name": "discord",
            "library": "fontawesome"
          },
          "href": "https://discord.gg/M2Y8VC2H"
        },
        {
          "anchor": "GitHub",
          "icon": {
            "name": "github",
            "library": "fontawesome"
          },
          "href": "https://github.com/itsperini/opendot"
        },
        {
          "anchor": "X profile",
          "icon": {
            "name": "x-twitter",
            "library": "fontawesome"
          },
          "href": "https://x.com/itsperini"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://opendot.ai/blog"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "expanded": true,
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Understand OpenDot",
        "icon": "network",
        "expanded": true,
        "pages": ["architecture", "device-firmware-hardware"]
      },
      {
        "group": "Console workflow",
        "icon": "workflow",
        "expanded": true,
        "pages": [
          "login-signup",
          "agent-studio",
          "configuration",
          "browser-test",
          "dot-device",
          "settings-api-keys"
        ]
      },
      {
        "group": "Operate and deploy",
        "icon": "server",
        "expanded": true,
        "pages": [
          "runtime-configuration",
          "authentication",
          "database-inspection",
          "render-deployment"
        ]
      },
      {
        "group": "Contributing",
        "icon": "git-pull-request",
        "expanded": false,
        "pages": ["contributing", "contribution-areas", "roadmap", "repo-map"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/itsperini/opendot"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Website",
      "href": "https://opendot.ai"
    }
  }
}
