# Copy this file to .env at the repository root.
# Leave POSTGRES_URI empty for local Docker Compose or localhost Postgres defaults.

WEB_PORT=5173
RUNTIME_PORT=8787
POSTGRES_PORT=5432

POSTGRES_DB=opendot
POSTGRES_USER=opendot
POSTGRES_PASSWORD=opendot
POSTGRES_URI=
POSTGRES_SSL=false

SUPABASE_URL=
SUPABASE_JWT_SECRET=
OPENDOT_SESSION_SECRET=opendot-local-dev-session-secret-change-me
OPENDOT_SESSION_TTL=30d
OPENDOT_LOCAL_AUTH_DISABLED=false
PLATFORM_AUTH_REQUIRED=true
OPENDOT_RUNTIME_INTERNAL_SECRET=opendot-local-runtime-internal-secret-change-me
OPENDOT_RUNTIME_PUBLIC_HTTP_URL=http://localhost:8787
OPENDOT_RUNTIME_PUBLIC_WS_URL=ws://localhost:8787/voice
PLATFORM_API_INTERNAL_URL=http://localhost:8788/api

DEEPGRAM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.1
OPENDOT_SYSTEM_PROMPT=You are a concise voice assistant. Answer naturally in one or two short spoken paragraphs.
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANGUAGE=en-US
DEEPGRAM_ENDPOINTING_MS=900
DEEPGRAM_UTTERANCE_END_MS=1000
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_TTS_ENCODING=mp3
DEEPGRAM_TTS_SAMPLE_RATE=24000
MIN_TRANSCRIPT_CHARS=2
CLOSE_DEVICE_AFTER_TURN=true
CLOSE_DEVICE_AFTER_TURN_DELAY_MS=300

VITE_PLATFORM_API_URL=/api
VITE_RUNTIME_WS_URL=ws://localhost:8787/voice
VITE_RUNTIME_HTTP_URL=http://localhost:8787
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
